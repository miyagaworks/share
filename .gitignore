# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example.buyout
!.env.example.monthly

# vercel
.vercel

# パートナー環境（機密情報を含む）- テンプレートは除外
partners/*/
!partners/_template/

# typescript
*.tsbuildinfo
next-env.d.ts

# バックアップファイルを無視
backup_*
*.bak
*.backup
*.tar.gz