# ============================================
# 月額型（ホワイトラベル）環境変数テンプレート
# ============================================
# Share本体と同一インフラ（共有Supabase / Vercel）で稼働する。
# マルチテナントをPartner/CorporateTenantモデルで論理分離。
# 買取型との違い: DEPLOYMENT_MODE を設定しない（デフォルト=月額型）

# ── ブランド設定（Share本体のデフォルト値） ──
# 月額型ではパートナーブランドはDBのPartnerモデルで管理。
# 以下はShare本体（デフォルト）のブランド設定。
BRAND_NAME=Share
BRAND_LOGO_URL=/logo.svg
BRAND_FAVICON_URL=/pwa/favicon.ico
BRAND_PRIMARY_COLOR="#3B82F6"
BRAND_SECONDARY_COLOR=
BRAND_COMPANY_NAME=株式会社Senrigan
BRAND_COMPANY_URL=https://senrigan.systems
BRAND_COMPANY_ADDRESS=〒731-0137 広島県広島市安佐南区山本2-3-35
BRAND_COMPANY_PHONE=082-209-0181
BRAND_COMPANY_REPRESENTATIVE=宮川 清実
BRAND_SUPPORT_EMAIL=support@sns-share.com
BRAND_PRIVACY_URL=/legal/privacy
BRAND_TERMS_URL=/legal/terms
BRAND_TAGLINE=すべてのSNS、ワンタップで

# ── ブランド設定（クライアントサイド） ──
NEXT_PUBLIC_BRAND_NAME=Share
NEXT_PUBLIC_BRAND_TAGLINE=すべてのSNS、ワンタップで
NEXT_PUBLIC_BRAND_COMPANY_NAME=株式会社Senrigan
NEXT_PUBLIC_BRAND_COMPANY_ADDRESS=〒731-0137 広島県広島市安佐南区山本2-3-35
NEXT_PUBLIC_BRAND_SUPPORT_EMAIL=support@sns-share.com
NEXT_PUBLIC_BRAND_COMPANY_URL=https://senrigan.systems
NEXT_PUBLIC_BRAND_COMPANY_PHONE=082-209-0181
NEXT_PUBLIC_APP_URL=https://app.sns-share.com

# ── 管理者設定 ──
# 月額型ではSuper Admin / Financial Admin を有効化。
SUPER_ADMIN_EMAIL=admin@sns-share.com
ADMIN_EMAIL_DOMAIN=@sns-share.com
ADMIN_EMAIL=admin@sns-share.com

# ── 機能フラグ ──
# 月額型ではパートナーモジュール・Super Admin を有効化。
FEATURE_FINANCIAL_ADMIN=true
FEATURE_PARTNER_MODULE=true
FEATURE_SUPER_ADMIN=true

# ── カスタムドメイン（Phase 7） ──
# パートナーのカスタムドメインをJSON形式で設定。
# パートナー追加時に更新が必要（再デプロイも必要）。
PARTNER_DOMAIN_MAP='{}'
CSP_ALLOWED_DOMAINS=
VERCEL_API_TOKEN=                                    # Vercel APIトークン（ドメイン自動登録用）
VERCEL_PROJECT_ID=                                   # Vercel プロジェクトID
VERCEL_TEAM_ID=                                      # Vercel チームID（チーム利用時のみ）

# ── メール送信（Resend） ──
FROM_NAME=Share
FROM_EMAIL=noreply@sns-share.com
SUPPORT_EMAIL=support@sns-share.com
RESEND_API_KEY=re_xxxxxxxxxx

# ── 認証（NextAuth） ──
NEXTAUTH_URL=https://app.sns-share.com
NEXTAUTH_SECRET=ランダム文字列

# ── データベース（Supabase） ──
DATABASE_URL=postgresql://...
DIRECT_URL=postgresql://...

# ── Stripe（パートナー月額サブスクリプション用） ──
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# 個人プラン用（Share本体のサブスクリプション）
STRIPE_INDIVIDUAL_MONTHLY_PRICE_ID=price_xxx
STRIPE_INDIVIDUAL_YEARLY_PRICE_ID=price_xxx
# パートナー月額プラン用
STRIPE_PARTNER_BASIC_PRICE_ID=price_xxx
STRIPE_PARTNER_PRO_PRICE_ID=price_xxx
STRIPE_PARTNER_PREMIUM_PRICE_ID=price_xxx

# ── Google OAuth ──
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx

# ── reCAPTCHA ──
RECAPTCHA_SECRET_KEY=xxx
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=xxx

# ── 画像ストレージ（Supabase Storage） ──
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_ROLE_KEY=xxx
