# ============================================
# 買取型（ホワイトラベル）環境変数テンプレート
# ============================================
# 買取パートナーごとに独立したVercel/Supabaseで稼働する。
# 同一リポジトリ・同一ブランチを参照し、この環境変数で分岐する。

# ── デプロイモード ──
DEPLOYMENT_MODE=buyout                              # "buyout" 固定（買取型を示す）

# ── ブランド設定（サーバーサイド） ──
# getBrandConfig() で参照される。メールテンプレート・APIで使用。
BRAND_NAME=パートナーブランド名                       # サービスブランド名
BRAND_LOGO_URL=/logo.svg                            # ロゴ画像パス（publicディレクトリ配下）
BRAND_FAVICON_URL=/pwa/favicon.ico                  # ファビコン画像パス
BRAND_PRIMARY_COLOR=#3B82F6                         # メインカラー（HEX形式）
BRAND_SECONDARY_COLOR=                              # サブカラー（任意）
BRAND_COMPANY_NAME=パートナー会社名                   # 運営会社名（フッター・メール署名に表示）
BRAND_COMPANY_URL=https://example.com               # 運営会社のウェブサイトURL
BRAND_COMPANY_ADDRESS=〒000-0000 住所                # 会社住所（特定商取引法表記等に使用）
BRAND_COMPANY_PHONE=000-000-0000                    # 会社電話番号（特定商取引法表記等に使用）
BRAND_COMPANY_REPRESENTATIVE=代表者名                # 代表者名（特定商取引法表記等に使用）
BRAND_SUPPORT_EMAIL=support@example.com             # サポート用メールアドレス
BRAND_PRIVACY_URL=/legal/privacy                    # プライバシーポリシーURL（相対パス）
BRAND_TERMS_URL=/legal/terms                        # 利用規約URL（相対パス）
BRAND_TAGLINE=サービスのタグライン                    # キャッチコピー（認証画面等に表示）

# ── ブランド設定（クライアントサイド） ──
# NEXT_PUBLIC_ 接頭辞によりブラウザ側でも参照可能。
# defaults.ts の定数で使用される。
NEXT_PUBLIC_DEPLOYMENT_MODE=buyout                  # クライアント側デプロイモード判定
NEXT_PUBLIC_BRAND_NAME=パートナーブランド名           # クライアント側ブランド名
NEXT_PUBLIC_BRAND_TAGLINE=サービスのタグライン        # クライアント側タグライン
NEXT_PUBLIC_BRAND_COMPANY_NAME=パートナー会社名       # クライアント側会社名
NEXT_PUBLIC_BRAND_COMPANY_ADDRESS=〒000-0000 住所    # クライアント側会社住所
NEXT_PUBLIC_BRAND_SUPPORT_EMAIL=support@example.com # クライアント側サポートメール
NEXT_PUBLIC_BRAND_COMPANY_URL=https://example.com   # クライアント側会社URL
NEXT_PUBLIC_BRAND_COMPANY_PHONE=000-000-0000        # クライアント側会社電話番号
NEXT_PUBLIC_APP_URL=https://app.example.com         # アプリケーションのベースURL

# ── 管理者設定 ──
# 買取型では空にしてShare管理者判定を無効化する。
# パートナー独自の管理者はADMIN_EMAILで指定。
SUPER_ADMIN_EMAIL=                                  # 空にする（Share super-admin判定を無効化）
ADMIN_EMAIL_DOMAIN=                                 # 空にする（financial-admin判定を無効化）
ADMIN_EMAIL=admin@example.com                       # パートナーの管理者メールアドレス

# ── 機能フラグ ──
# 買取型で不要な機能を無効化する。
FEATURE_FINANCIAL_ADMIN=false                       # 財務管理機能（Share内部用のため無効）
FEATURE_PARTNER_MODULE=false                        # パートナー募集モジュール（Share専用のため無効）
FEATURE_SUPER_ADMIN=false                           # Super Admin機能（別の仕組みで管理）

# ── メール送信（Resend） ──
# パートナー独自ドメインのメールアドレスを設定。
# Resendでドメイン認証が必要。
FROM_NAME=パートナーブランド名                       # メール差出人名
FROM_EMAIL=noreply@example.com                      # メール差出人アドレス（Resend認証済みドメイン）
SUPPORT_EMAIL=support@example.com                   # サポート窓口メールアドレス
RESEND_API_KEY=re_xxxxxxxxxx                        # Resend APIキー

# ── 認証（NextAuth） ──
NEXTAUTH_URL=https://app.example.com                # アプリケーションURL（NextAuth用）
NEXTAUTH_SECRET=ランダム文字列                       # ⚠️ 環境間で絶対に同じ値にしないこと

# ── データベース（Supabase） ──
# パートナー専用Supabaseプロジェクトの接続情報。
DATABASE_URL=postgresql://...                       # Supabase接続URL（Pooler経由）
DIRECT_URL=postgresql://...                         # Supabase直接接続URL（マイグレーション用）

# ── Stripe ──
# パートナーが自社顧客に課金する場合のみ設定。
# 不要な場合は空のまま。
STRIPE_SECRET_KEY=sk_live_xxx                       # Stripeシークレットキー
STRIPE_PUBLISHABLE_KEY=pk_live_xxx                  # Stripe公開キー
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx      # クライアント側Stripe公開キー
STRIPE_WEBHOOK_SECRET=whsec_xxx                     # Stripe Webhookシークレット
STRIPE_INDIVIDUAL_MONTHLY_PRICE_ID=price_xxx        # 個人プラン月額Price ID
STRIPE_INDIVIDUAL_YEARLY_PRICE_ID=price_xxx         # 個人プラン年額Price ID

# ── Google OAuth ──
# パートナー自前のGCPプロジェクトでOAuthクライアントを作成推奨。
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com     # Google OAuth Client ID
GOOGLE_CLIENT_SECRET=GOCSPX-xxx                     # Google OAuth Client Secret

# ── reCAPTCHA ──
# ※ 現在バイパス実装中。有効化する場合はパートナーごとに発行。
RECAPTCHA_SECRET_KEY=xxx                            # reCAPTCHAシークレットキー
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=xxx                  # reCAPTCHAサイトキー

# ── 画像ストレージ（Supabase Storage） ──
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co    # Supabase URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx                   # Supabase匿名キー
SUPABASE_SERVICE_ROLE_KEY=xxx                       # Supabase Service Roleキー
